{
  "manifest_version": 3,
  "name": "B2R",
  "version": "1.8.3",
  "description": "Dịch và đồng bộ comment từ Backlog sang Redmine (B2R).",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "default_locale": "vi",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.backlog.com/*",
    "*://*.backlog.jp/*",
    "https://redmine.splus-software.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.cerebras.ai/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.backlog.com/*",
        "*://*.backlog.jp/*"
      ],
      "js": [
        "src/modules/constants/models.js",
        "src/modules/constants/icons.js",
        "src/modules/constants/prompts.js",
        "src/constants.js",
        "src/modules/utils/helpers.js",
        "src/modules/utils/logger.js",
        "src/modules/utils/markdown.js",
        "src/modules/ui/styles.js",
        "src/modules/ui/toast.js",
        "src/modules/ui/modal.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://redmine.splus-software.com/*"
      ],
      "js": [
        "src/modules/constants/models.js",
        "src/modules/constants/icons.js",
        "src/modules/constants/prompts.js",
        "src/constants.js",
        "src/modules/utils/helpers.js",
        "src/modules/utils/logger.js",
        "src/modules/ui/styles.js",
        "src/modules/ui/toast.js",
        "src/modules/ui/modal.js",
        "src/modules/services/redmine.js",
        "src/modules/services/report-log-time.js",
        "src/redmine_content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "B2R - Backlog to Redmine"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/images/*.jpg",
        "assets/images/*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
