{
  "manifest_version": 3,
  "name": "Backlog to Redmine Translator",
  "version": "1.4.3",
  "description": "Dịch comment từ Backlog sang tiếng Việt bằng Gemini và đẩy sang Redmine.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.backlog.com/*",
    "*://*.backlog.jp/*",
    "https://redmine.splus-software.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.cerebras.ai/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://shift7.backlog.com/*"],
      "js": [
        "src/constants.js",
        "src/modules/utils/helpers.js",
        "src/modules/utils/markdown.js",
        "src/modules/ui/styles.js",
        "src/modules/ui/toast.js",
        "src/modules/ui/modal.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://redmine.splus-software.com/*"],
      "js": [
        "src/constants.js",
        "src/modules/utils/helpers.js",
        "src/modules/ui/styles.js",
        "src/modules/ui/toast.js",
        "src/modules/ui/modal.js",
        "src/redmine_content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "action": {
    "default_title": "Translate Backlog Comment"
  }
}
